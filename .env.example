# 참조: 06_ROADMAP/05_SCAFFOLDING.md §4
# 로컬 오버라이드는 .env.local (gitignored). 운영 키는 Vercel Environment Variables.

# ── Supabase (신 API 키 형식: sb_publishable_* / sb_secret_*)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_JWT_SECRET=

# ── Cloudflare R2 (사진 3-tier)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_HOT=mount-photos-hot
R2_BUCKET_WARM=mount-photos-warm
R2_BUCKET_COLD=mount-photos-cold
R2_PUBLIC_BASE_URL=https://photos.mountpartners.cloud

# ── Solapi (카카오 알림톡 + SMS)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_PFID=
SOLAPI_SENDER_PHONE=

# ── PortOne v2 (아임포트)
PORTONE_STORE_ID=
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=

# ── 카카오 (Map + 알림톡 발신자 검증)
NEXT_PUBLIC_KAKAO_MAP_KEY=
KAKAO_REST_API_KEY=

# ── 쿠팡 CLS (MVP: CSV + mail2db. Phase 2: API)
COUPANG_CLS_API_KEY=
COUPANG_CLS_VENDOR_ID=

# ── 관측성
NEXT_PUBLIC_SENTRY_DSN_DRIVER=
NEXT_PUBLIC_SENTRY_DSN_ADMIN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=walltvpro
SENTRY_PROJECT_DRIVER=mount-driver
SENTRY_PROJECT_ADMIN=mount-admin
BETTER_STACK_SOURCE_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── 앱 URL (rev 5 · mountpartners.cloud 서브도메인)
NEXT_PUBLIC_APP_URL=https://app.mountpartners.cloud
NEXT_PUBLIC_ADMIN_URL=https://admin.mountpartners.cloud
NEXT_PUBLIC_APP_VERSION=0.1.0

# ── 로컬 오버라이드 (.env.local 에서):
